# 内核优化

CONFIG_HZ=1000
# CONFIG_HZ_100 is not set
CONFIG_HZ_1000=y

# --- 安全与体积优化 (合理) ---
# CONFIG_DEBUG_BUGVERBOSE is not set
# CONFIG_DEBUG_MEMORY_INIT is not set
# CONFIG_STACKTRACE is not set
# CONFIG_COREDUMP is not set
# CONFIG_PROC_PAGE_MONITOR is not set
# CONFIG_GENERIC_LIB_DEVMEM_IS_ALLOWED is not set

# 全部删除
# CONFIG_CPU_FREQ_GOV_SCHEDUTIL is not set
# CONFIG_CPU_FREQ_GOV_ONDEMAND is not set
# CONFIG_CPU_FREQ_GOV_CONSERVATIVE is not set
# CONFIG_CPU_FREQ_GOV_POWERSAVE is not set
# CONFIG_CPU_FREQ_GOV_USERSPACE is not set

CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
# CONFIG_STACKDEPOT is not set
CONFIG_IO_URING=y
CONFIG_NETFILTER_BPF_LINK=y

# ---高性能代理---
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_NET_CLS_BPF=y
CONFIG_NET_ACT_BPF=y
CONFIG_PCIE_MEDIATEK=y
CONFIG_BPF_JIT_ALWAYS_ON=y

# 全部关闭 Linux flow offload
# CONFIG_NET_FLOW_OFFLOAD is not set
# CONFIG_NF_FLOW_TABLE is not set
# CONFIG_NF_FLOW_TABLE_INET is not set
# CONFIG_NETFILTER_XT_TARGET_FLOWOFFLOAD is not set

# 下面三项可以安全关闭
# CONFIG_THERMAL_GOV_FAIR_SHARE is not set
# CONFIG_THERMAL_GOV_BANG_BANG is not set
# CONFIG_THERMAL_GOV_USER_SPACE is not set
# CONFIG_GRO_CELLS is not set

# --- 为了插件兼容性和高性能 eBPF (必须开启) ---
CONFIG_KALLSYMS=y

# 全部删除
# CONFIG_CPU_FREQ_GOV_ONDEMAND is not set
# CONFIG_CPU_FREQ_GOV_CONSERVATIVE is not set
# CONFIG_CPU_FREQ_GOV_POWERSAVE is not set
# CONFIG_CPU_FREQ_GOV_USERSPACE is not set

# 必须全部关闭
# CONFIG_NET_SELFTESTS is not set

# CONFIG_MTK_LVTS_THERMAL_DEBUGFS is not set
CONFIG_CONFIGFS_FS=y
# CONFIG_NET_FLOW_LIMIT is not set

# ===== 多核调度（MTK必须关）=====
CONFIG_RPS=y
CONFIG_RFS_ACCEL=y
CONFIG_XPS=y

# --  完全抢占低延迟模式--
# CONFIG_PREEMPT_VOLUNTARY_BUILD is not set
# CONFIG_PREEMPT_NONE_BUILD is not set
CONFIG_PREEMPT=y
# CONFIG_PREEMPT_NONE is not set
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
# CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL is not set
# CONFIG_PCI_DEBUG is not set
# CONFIG_DMATEST is not set
# CONFIG_PSTORE is not set
# CONFIG_DYNAMIC_DEBUG is not set
CONFIG_PCIEASPM_PERFORMANCE=y
# CONFIG_PCIEASPM_POWER_SUPERSAVE is not set
# CONFIG_PERF_EVENTS is not set
